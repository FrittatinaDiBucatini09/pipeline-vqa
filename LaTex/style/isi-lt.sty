\newcommand{\universita}[1]{%
  \renewcommand{\@universita}{\uppercase{#1}}}
\newcommand{\campus}[1]{%
  \renewcommand{\@campus}{\uppercase{#1}}}
\newcommand{\dipartimento}[1]{%
  \renewcommand{\@dipartimento}{\uppercase{#1}}}
